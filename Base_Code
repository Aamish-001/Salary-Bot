import streamlit as st
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_community.vectorstores import FAISS
from langchain_classic.chains.question_answering import load_qa_chain 
from langchain_ollama import OllamaLLM

#Upload Files
st.header(":green[_SalaryBot_]", divider="violet")

#Sidebar
with st.sidebar:
    st.title("Documents Upload")
    file = st.file_uploader("Upload your documents here", type=["pdf", "docx", "txt", "xlsx"], accept_multiple_files=True)

# CHANGE 1: collect chunks from ALL uploaded files (original code only kept the last file)
all_chunks = []

#Extract text from uploaded files
if file:
    for uploaded_file in file:
        text = ""

        if uploaded_file.type == "application/pdf":
            import PyPDF2
            pdf_reader = PyPDF2.PdfReader(uploaded_file)
            for page in pdf_reader.pages:
                text += page.extract_text() or ""

        elif uploaded_file.type == "application/vnd.openxmlformats-officedocument.wordprocessingml.document":
            import docx
            doc = docx.Document(uploaded_file)
            for para in doc.paragraphs:
                text += para.text + "\n"

        elif uploaded_file.type == "text/plain":
            text = uploaded_file.read().decode("utf-8")

        elif uploaded_file.type == "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet":
            import pandas as pd
            df = pd.read_excel(uploaded_file)
            text = df.to_string(index=False)

        else:
            st.warning(f"Unsupported file type: {uploaded_file.type}")
            continue

        #Break file into sizable chunks
        text_splitter = RecursiveCharacterTextSplitter(
            separators=["\n"],
            chunk_size=500,
            chunk_overlap=150,
            length_function=len
        )
        chunks = text_splitter.split_text(text)
        all_chunks.extend(chunks)  # CHANGE 1 continued: add to big list instead of overwriting

# Generating Embeddings
    try:
        from langchain_huggingface import HuggingFaceEmbeddings
    except ImportError:
        st.error("Install free local embeddings with: pip install langchain-huggingface sentence-transformers")
        st.stop()

    # CHANGE 2: build embeddings only once, save in session_state so it doesn't redo this on every keypress
    if "vector_store" not in st.session_state:
        embeddings = HuggingFaceEmbeddings(model_name="sentence-transformers/all-MiniLM-L6-v2")
        st.session_state.vector_store = FAISS.from_texts(all_chunks, embeddings)

    vector_store = st.session_state.vector_store

    # CHANGE 3: keep a running chat history
    if "chat_history" not in st.session_state:
        st.session_state.chat_history = []

    # show all previous messages
    for role, message in st.session_state.chat_history:
        with st.chat_message(role):
            st.write(message)

    # CHANGE 4: chat-style input box
    user_question = st.chat_input("Enter a question :")

    if user_question:
        with st.chat_message("user"):
            st.write(user_question)
        st.session_state.chat_history.append(("user", user_question))

        llm = OllamaLLM(
            temperature=0,
            model="llama3.2:latest"
        )

        # CHANGE 5: build conversation history string so LLM knows what was said before
        history_text = ""
        for role, message in st.session_state.chat_history[:-1]:
            label = "User" if role == "user" else "Assistant"
            history_text += f"{label}: {message}\n"

        # CHANGE 6: for the document search, combine the LAST real question + current message.
        # Problem before: "make it longer" was being searched in the documents,
        # which pulled random unrelated chunks and confused the LLM.
        # Fix: search using the last real question so we get the right document chunks.
        past_user_messages = [m for role, m in st.session_state.chat_history[:-1] if role == "user"]
        if past_user_messages:
            search_query = past_user_messages[-1] + " " + user_question
        else:
            search_query = user_question

        match = vector_store.similarity_search(search_query)

        question_with_history = f"""Previous conversation:
{history_text}
Current question: {user_question}"""

        chain = load_qa_chain(llm, chain_type="stuff")
        response = chain.run(input_documents=match, question=question_with_history)

        with st.chat_message("assistant"):
            st.write(response)
        st.session_state.chat_history.append(("assistant", response))

